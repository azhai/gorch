LOG_DIR = '/var/log'

[services]
[services.api]
BACK_OFF = 5
CRON = "0 */30 * * * *"
DEPENDS_ON = ["postgres"]
ENV_VARS = { DEBUG = "true", DATABASE_URL = "postgres://user:pass@localhost:5432/db" }
EXEC_CMD = "python3 manage.py runserver 0.0.0.0:8000"
RESTART_POLICY = "on-failure"
STDOUT = "/var/log/api.out.log"
STDERR = "/var/log/api.err.log"
WORK_DIR = "/home/ryan/app/backend"

[services.godoc]
BACK_OFF = 3
EXEC_CMD = './bin/godoc -http=127.0.0.1:6060'
RESTART_POLICY = 'on-failure'
STDERR = '/var/log/godoc.err.log'
STDOUT = '/var/log/godoc.out.log'
WORK_DIR = '/home/ryan/gopath'

[services.nginx]
DEPENDS_ON = ["api"]
EXEC_CMD = "nginx"
PID_FILE = "/var/run/nginx.pid"
RESTART_CMD = "nginx -s reload"
RESTART_POLICY = "always"

[services.postgres]
BACK_OFF = 3
EXEC_CMD = "postgres -D /var/lib/postgres"
RESTART_POLICY = "always"
STDOUT = "/var/log/postgres.log"

[services.test]
CRON = "30 */5 9-17 * * *"
EXEC_CMD = "/bin/date >> /tmp/time.log"
STDERR = '/var/log/test.err.log'
STDOUT = '/var/log/test.out.log'

[web]
WEB_AUTH = true
WEB_ADDR = "127.0.0.1:8080"
WEB_ENABLE = true
WEB_PASS = 'secret'
WEB_USER = 'admin'
# Mount the web UI and API under a sub-path, e.g. "/gorch" serves at
# http://host/gorch/api/services. Leave empty ("") for root mount.
# No rebuild needed — the binary reads this at startup and injects
# window.__URL_PREFIX__ into the SPA at runtime.
URL_PREFIX = ""
TOTP_ENABLE = false
# 生成命令: openssl rand -hex 32
TOTP_SECRET = ''
TOTP_DB = 'auth_totp.db'